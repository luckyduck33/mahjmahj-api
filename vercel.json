{
  "crons": [
    {
      "path": "/api/cron/expire-events",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/refresh-news",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
